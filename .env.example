# Porta publicada do Nginx (site estático)
WEB_PORT=8080

# API Node (perfil admin) — porta no host para debug direto (opcional)
API_PORT=3000

# PostgreSQL — perfis: db (só banco) ou admin (banco + API)
POSTGRES_USER=catalogo
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=catalogo
POSTGRES_PORT=5432

# Build da API — registry npm (útil se registry.npmjs.org cair ou TLS reset)
# NPM_REGISTRY=https://registry.npmmirror.com/

# Proxy corporativo no build Docker (opcional)
# HTTP_PROXY=http://usuario:senha@proxy.empresa:8080
# HTTPS_PROXY=http://usuario:senha@proxy.empresa:8080
# NO_PROXY=localhost,127.0.0.1
